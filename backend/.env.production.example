PORT=5000
NODE_ENV=production
JWT_SECRET=replace_with_strong_secret
JWT_EXPIRES_IN=7d

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=athena
DB_PASSWORD=replace_me
DB_NAME=athena
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
DB_SSL_CA=

FRONTEND_ORIGIN=https://your-domain.com
ENCRYPTION_KEY=replace_with_32_characters

FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=

# OTP / SMS (required in production)
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# Escalation worker
ESCALATION_WORKER_ENABLED=true
ESCALATION_POLL_MS=15000
ESCALATION_BATCH_SIZE=20
